INDIAN_KANOON_API_TOKEN=replace_with_your_indian_kanoon_api_token
# Optional OpenAI-compatible endpoint. When absent, source-grounded deterministic summaries are used.
LEGAL_LLM_BASE_URL=https://your-llm-provider.example/v1
LEGAL_LLM_API_KEY=replace_with_your_server_side_llm_api_key
LEGAL_LLM_MODEL=your-model-name
# Keep false for efficient bulk streams; true enables per-paragraph LLM insights.
LEGAL_LLM_PARAGRAPH_INSIGHTS=false
